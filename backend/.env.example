# Application
NODE_ENV=development
PORT=3001

# Database (MongoDB)
# Local: mongodb://localhost:27017/truuth_portal
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/truuth_portal?retryWrites=true&w=majority
MONGODB_URL="mongodb+srv://your-username:your-password@your-cluster.mongodb.net/truuth_portal?retryWrites=true&w=majority"

# JWT Configuration
JWT_SECRET="your-super-secret-key-at-least-32-characters-long-change-in-production"
JWT_EXPIRES_IN="24h"

# Truuth API Configuration (NEVER expose to frontend)
TRUUTH_CLASSIFIER_URL="https://api.au.truuth.id/document-management/v1/classify"
TRUUTH_VERIFY_BASE_URL="https://submissions.api.au.truuth.id/verify-document/v1/tenants"
TRUUTH_TENANT_ALIAS="your-tenant-alias"
TRUUTH_API_KEY="your-api-key"
TRUUTH_API_SECRET="your-api-secret"
