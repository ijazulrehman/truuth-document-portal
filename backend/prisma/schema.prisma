// Prisma Schema for Truuth Document Verification Portal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  documents DocumentSubmission[]

  @@map("users")
}

// Document types enum
enum DocumentType {
  AUSTRALIAN_PASSPORT
  AUSTRALIAN_DRIVERS_LICENCE
  RESUME
}

// Verification status enum
enum VerificationStatus {
  PROCESSING
  DONE
  FAILED
}

// Document submission model
model DocumentSubmission {
  id                 String             @id @default(uuid())
  userId             String             @map("user_id")
  documentType       DocumentType       @map("document_type")
  documentVerifyId   String?            @map("document_verify_id")
  status             VerificationStatus @default(PROCESSING)
  fileName           String             @map("file_name")
  mimeType           String             @map("mime_type")
  verificationResult Json?              @map("verification_result")
  errorMessage       String?            @map("error_message")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Constraints: One document per type per user
  @@unique([userId, documentType])
  // Indexes for common queries
  @@index([userId])
  @@index([status])
  @@map("document_submissions")
}
